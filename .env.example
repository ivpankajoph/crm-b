# Existing application configuration
MONGODB_URI=mongodb://127.0.0.1:27017/crm
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173

# Plivo credentials (keep these on the server only)
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token

# Public HTTPS origin where Plivo can reach this API (no trailing slash).
# For local testing, use an HTTPS tunnel such as https://your-subdomain.ngrok-free.app
PUBLIC_API_URL=https://hhc99crk-8083.inc1.devtunnels.ms

# Applied to bare Indian 10-digit CRM phone numbers.
DEFAULT_PHONE_COUNTRY_CODE=91
