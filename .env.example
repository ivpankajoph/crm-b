# Existing application configuration
MONGODB_URI=mongodb://127.0.0.1:27017/crm
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173

# Plivo credentials (keep these on the server only)
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token

# Public HTTPS origin where Plivo can reach this API (no trailing slash).
# For local testing, use an HTTPS tunnel such as https://your-subdomain.ngrok-free.app
PUBLIC_API_URL=https://hhc99crk-8083.inc1.devtunnels.ms

# Applied to bare Indian 10-digit CRM phone numbers.
DEFAULT_PHONE_COUNTRY_CODE=91

# Email Marketing module foundation
# Sending and DNS verification stay disabled until SES/Redis are configured.
EMAIL_MARKETING_ENABLED=true
EMAIL_MARKETING_DEFAULT_TIMEZONE=Asia/Kolkata
EMAIL_MARKETING_MAX_IMPORT_ROWS=10000
EMAIL_MARKETING_MAX_PAGE_SIZE=100
EMAIL_MARKETING_SENDING_ENABLED=false
EMAIL_MARKETING_DOMAIN_VERIFICATION_ENABLED=false

# Backend Part 3: enable only after SES, public HTTPS URL, and Redis are ready.
EMAIL_MARKETING_QUEUE_ENABLED=false
EMAIL_MARKETING_REDIS_URL=redis://127.0.0.1:6379
EMAIL_MARKETING_SES_REGION=ap-south-1
EMAIL_MARKETING_SES_CONFIGURATION_SET=
EMAIL_MARKETING_PLATFORM_FROM_NAME=SellersLogin
EMAIL_MARKETING_PLATFORM_FROM_EMAIL=noreply@sellerslogin.com
EMAIL_MARKETING_PLATFORM_REPLY_TO=noreply@sellerslogin.com
EMAIL_MARKETING_PUBLIC_URL=https://api.example.com
EMAIL_MARKETING_TRACKING_SECRET=replace-with-a-separate-long-random-secret
EMAIL_MARKETING_WEBHOOK_SECRET=replace-with-a-separate-webhook-secret
EMAIL_MARKETING_SEND_CONCURRENCY=5

# Backend Part 4: optional credits. Keep purchases disabled without a payment gateway.
EMAIL_MARKETING_CREDITS_ENFORCED=false
EMAIL_MARKETING_CREDIT_PURCHASES_ENABLED=false
EMAIL_MARKETING_INITIAL_CREDITS=0

# AWS SDK standard credentials. In production, prefer an IAM role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
